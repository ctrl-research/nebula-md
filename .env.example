# Nebula Configuration
# Copy this file to .env and customize as needed.
# Environment variables (NEBULA_*) override .env values.

# Site name displayed in the header and page titles
NEBULA_SITE_NAME=Nebula 🪨

# Default theme: "dark" or "light"
NEBULA_SITE_THEME=dark

# Vault directory containing markdown files (default: "../vault")
# NEBULA_INPUT=/path/to/vault

# Output directory for generated HTML (default: "../output")
# NEBULA_OUTPUT=/path/to/output

# Comma-separated list of directory names to ignore (e.g. templates,scripts)
# NEBULA_IGNORED_DIRS=templates,scripts

# Size graph nodes by edge count (true/false)
# When enabled, nodes with more connections appear larger
NEBULA_GRAPH_NODE_SIZE_BY_EDGES=true

# Clean URLs: emit internal links without the .html extension (true/false, default: true)
# Requires a host that serves /foo as foo.html (e.g. GitHub Pages). Set to false
# for hosts that don't do extensionless resolution, so links keep their .html.
# NEBULA_CLEAN_URLS=true
