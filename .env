# Basalt Configuration
# Copy this file to .env and customize as needed.
# Environment variables (BASALT_*) override .env values.

# Site name displayed in the header and page titles
BASALT_SITE_NAME=Jon's Basalt 🪨

# Default theme: "dark" or "light"
BASALT_SITE_THEME=dark

BASALT_GRAPH_NODE_SIZE_BY_EDGES=true

BASALT_FEATURE_AUTO_FOLDER_MOC=true

BASALT_GRAPH_MODE=nebula
