# Nebula Configuration
# Copy this file to .env and customize as needed.
# Environment variables (NEBULA_*) override .env values.

# Site name displayed in the header and page titles
NEBULA_SITE_NAME=Jon's Nebula 🪨

# Default theme: "dark" or "light"
NEBULA_SITE_THEME=dark

NEBULA_GRAPH_NODE_SIZE_BY_EDGES=true

NEBULA_FEATURE_AUTO_FOLDER_MOC=true

NEBULA_GRAPH_MODE=nebula
